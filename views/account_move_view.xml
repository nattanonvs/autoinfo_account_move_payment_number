<odoo>
    <!-- Form view -->
    <record id="view_vendor_bill_form_inherit_payment_number" model="ir.ui.view">
        <field name="name">account.move.vendor.bill.payment.number</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="payment_number" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Tree view -->
    <record id="view_vendor_bill_tree_inherit_payment_number" model="ir.ui.view">
        <field name="name">account.move.vendor.bill.tree.payment.number</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <field name="payment_number"/>
            </xpath>
        </field>
    </record>
</odoo>
